# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env

# Token de HuggingFace (necesario para descargar modelos)
HF_TOKEN=your_huggingface_token_here

# LLM - Modo desarrollo (Ollama local)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL_NAME=llama3.1:8b
LLM_API_KEY=

# LLM - Modo producción (vLLM en Triton)
# LLM_PROVIDER=vllm
# LLM_BASE_URL=http://vllm:8000/v1
# LLM_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
# LLM_API_KEY=dummy-key-vllm-local

# Embeddings - Modo desarrollo (HuggingFace local)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BASE_URL=

# Embeddings - Modo producción (TEI en Triton)
# EMBEDDING_PROVIDER=tei
# EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_BASE_URL=http://tei:80

# Qdrant
QDRANT_URL=http://localhost:6333

# Frontend
FRONTEND_URL=http://localhost:8501
BACKEND_URL=http://localhost:8000
